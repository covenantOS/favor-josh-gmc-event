---
---
<section class="hero" id="top">
  <div class="container hero__grid">
    <div class="hero__content">
      <span class="eyebrow eyebrow--chip hero__chip">Apostolic Partner · Global Methodist Church</span>
      <h1 class="display">Mobilize your church to <span class="accent">transform nations</span>.</h1>
      <p class="hero__lede">Transformed hearts transform nations.</p>
      <div class="hero__ctas">
        <a class="hero__cta" href="#host">
          Invite Josh to a Discover Favor Sunday
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a class="hero__scroll" href="#impact">Or learn more</a>
      </div>
    </div>

    <div class="hero__collage" aria-hidden="true">
      <figure class="hero__photo hero__photo--primary">
        <img src="/images/banner-girls.jpg" alt="" loading="eager" fetchpriority="high" />
      </figure>
      <figure class="hero__photo hero__photo--secondary">
        <img src="/images/field-woman-smile.jpg" alt="" loading="eager" />
      </figure>
      <div class="hero__sticker">
        <strong>1,400</strong>
        <span>Indigenous Missionaries · 14+ Nations</span>
      </div>
    </div>
  </div>
</section>
