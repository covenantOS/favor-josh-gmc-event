---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="footer-brand">
      <div class="name">Favor International</div>
      <p class="vision">Transforming nations with the power of the Gospel through prayer movements and indigenous missionaries.</p>
      <div class="badges">
        <span class="badge">ECFA</span>
        <span class="badge">Charity Navigator</span>
        <span class="badge">GuideStar</span>
        <span class="badge">501(c)(3)</span>
      </div>
    </div>

    <div>
      <h4>Connect</h4>
      <ul>
        <li><a href="https://favorintl.org" target="_blank" rel="noopener">favorintl.org</a></li>
        <li><a href="mailto:josh@favorintl.org">josh@favorintl.org</a></li>
        <li><a href="tel:+18133451005">813-345-1005</a></li>
      </ul>
    </div>

    <div>
      <h4>Take a Step</h4>
      <ul>
        <li><a href="#pray">Pray with us</a></li>
        <li><a href="https://favorintl.org/donate" target="_blank" rel="noopener">Give</a></li>
        <li><a href="#host">Host an event</a></li>
      </ul>
    </div>
  </div>

  <div class="container site-footer__bottom">
    <span>© {year} Favor International</span>
    <span>Built for AECC · Global Methodist Church</span>
  </div>
</footer>
